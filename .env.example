APP_ENV=development
MILVUS_URI=http://127.0.0.1:19530
ELASTICSEARCH_URL=http://127.0.0.1:9200
NEO4J_URI=bolt://127.0.0.1:7687
REDIS_URL=redis://127.0.0.1:6379/0

# --- 本地部署 Qwen 模型（简单任务：意图分类、查询改写） ---
QWEN_INTENT_ENDPOINT=http://127.0.0.1:8001/v1
QWEN_REWRITE_ENDPOINT=http://127.0.0.1:8000/v1
QWEN_INTENT_MODEL=Qwen2.5-1.5B-Instruct-QLoRA
QWEN_REWRITE_MODEL=Qwen2.5-7B-Instruct-QLoRA

# --- 硅基流动 SiliconFlow 托管 DeepSeek（复杂任务：回答生成、RAPTOR 摘要、质量评估） ---
SILICONFLOW_ENDPOINT=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=your-siliconflow-api-key
DEEPSEEK_ANSWER_MODEL=deepseek-ai/DeepSeek-V2.5
DEEPSEEK_SUMMARIZER_MODEL=deepseek-ai/DeepSeek-V2.5
DEEPSEEK_JUDGE_MODEL=deepseek-ai/DeepSeek-V2.5

# --- 向量化与精排 ---
QWEN_EMBEDDING_ENDPOINT=http://127.0.0.1:8003/v1
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
RERANK_ENDPOINT=http://127.0.0.1:8004/rerank
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# --- OCR / ASR ---
OCR_ENDPOINT=http://127.0.0.1:8090/ocr
ASR_ENDPOINT=http://127.0.0.1:8091/transcribe
