# Python RAG服务 - .env配置文件模板
# 路径: /home/sun/javabackend/material-rag-service/.env.example

# OpenAI配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1

# Milvus配置
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530

# RabbitMQ配置
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Redis配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# MongoDB配置
MONGODB_URI=mongodb://127.0.0.1:27017/ns_bbs

# Flask配置
FLASK_ENV=production
FLASK_PORT=5050
FLASK_DEBUG=False

# Java后端回调URL
JAVA_CALLBACK_URL=http://127.0.0.1:7014/api/material/vectorize/callback

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
