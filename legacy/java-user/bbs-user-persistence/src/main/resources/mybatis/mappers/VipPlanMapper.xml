<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.liang.bbs.user.persistence.mapper.VipPlanMapper">

    <resultMap id="BaseResultMap" type="com.liang.bbs.user.persistence.entity.VipPlanPo">
        <id column="id" jdbcType="INTEGER" property="id" />
        <result column="name" jdbcType="VARCHAR" property="name" />
        <result column="duration_days" jdbcType="INTEGER" property="durationDays" />
        <result column="price" jdbcType="DECIMAL" property="price" />
        <result column="original_price" jdbcType="DECIMAL" property="originalPrice" />
        <result column="description" jdbcType="VARCHAR" property="description" />
        <result column="sort_order" jdbcType="INTEGER" property="sortOrder" />
        <result column="status" jdbcType="TINYINT" property="status" />
        <result column="create_time" jdbcType="TIMESTAMP" property="createTime" />
        <result column="update_time" jdbcType="TIMESTAMP" property="updateTime" />
    </resultMap>

    <sql id="Base_Column_List">
        id, name, duration_days, price, original_price, description, sort_order, status, create_time, update_time
    </sql>

    <select id="selectAvailablePlans" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" />
        FROM vip_plan
        WHERE status = 1
        ORDER BY sort_order ASC, id ASC
    </select>

    <select id="selectByPrimaryKey" parameterType="java.lang.Integer" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" />
        FROM vip_plan
        WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="com.liang.bbs.user.persistence.entity.VipPlanPo" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO vip_plan (name, duration_days, price, original_price, description, sort_order, status, create_time, update_time)
        VALUES (#{name}, #{durationDays}, #{price}, #{originalPrice}, #{description}, #{sortOrder}, #{status}, #{createTime}, #{updateTime})
    </insert>

    <update id="updateByPrimaryKeySelective" parameterType="com.liang.bbs.user.persistence.entity.VipPlanPo">
        UPDATE vip_plan
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="durationDays != null">duration_days = #{durationDays},</if>
            <if test="price != null">price = #{price},</if>
            <if test="originalPrice != null">original_price = #{originalPrice},</if>
            <if test="description != null">description = #{description},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE id = #{id}
    </update>

</mapper>
